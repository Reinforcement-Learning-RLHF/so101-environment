<mujoco model="scene">
  <include file="so101.xml" />

  <option timestep="0.002" iterations="80" solver="Newton" tolerance="1e-10"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="160" elevation="-20" />
  </visual>

  <asset>
      <mesh name="cup_mesh" file="cup.stl" scale="0.0005 0.0005 0.0005"/>
      <material name="cup_mat" rgba="0.2 0.6 1 1"/> 
  </asset>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
        height="3072" />
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
        rgb2="0.1 0.2 0.3"
        markrgb="0.8 0.8 0.8" width="300" height="300" />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
        reflectance="0.2" />
  </asset>

  <worldbody>
    <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
    <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

    <body name="table" pos="0.4 0 0">
      <geom name="table_top" type="box" size="0.3 0.4 0.02" pos="0 0 0.4" rgba="0.4 0.3 0.2 1" friction="1 0.005 0.0001"/>
      
      <geom name="leg1" type="cylinder" size="0.02 0.2" pos="0.25 0.35 0.2" rgba="0.2 0.2 0.2 1"/>
      <geom name="leg2" type="cylinder" size="0.02 0.2" pos="-0.25 0.35 0.2" rgba="0.2 0.2 0.2 1"/>
      <geom name="leg3" type="cylinder" size="0.02 0.2" pos="0.25 -0.35 0.2" rgba="0.2 0.2 0.2 1"/>
      <geom name="leg4" type="cylinder" size="0.02 0.2" pos="-0.25 -0.35 0.2" rgba="0.2 0.2 0.2 1"/>
    </body>

    <body name="target_cup" pos="0.55 0.1 0.42">
        <site name="target_center" pos="0 0 0.04" size="0.005" rgba="0 0 0 0"/>        
        <geom name="t_bottom" type="box" size="0.02 0.02 0.003" pos="0 0 0.003" rgba="0 0 1 0.2"/>
        <geom name="t_wall_n" type="box" size="0.02 0.002 0.033" pos="0 0.020 0.033" rgba="0 0 1 0.2"/>
        <geom name="t_wall_s" type="box" size="0.02 0.002 0.033" pos="0 -0.020 0.033" rgba="0 0 1 0.2"/>
        <geom name="t_wall_e" type="box" size="0.002 0.02 0.033" pos="0.020 0 0.033" rgba="0 0 1 0.2"/>
        <geom name="t_wall_w" type="box" size="0.002 0.02 0.033" pos="-0.020 0 0.033" rgba="0 0 1 0.2"/>
    </body>

    <body name="source_cup" pos="0.55 -0.1 0.42">
        <freejoint/>
        <inertial pos="0 0 0.03" mass="0.05" diaginertia="0.0001 0.0001 0.0001"/>         
        <geom name="s_bottom" type="box" size="0.02 0.02 0.003" pos="0 0 0.003" rgba="1 0 0 0.2"/>
        <geom name="s_wall_n" type="box" size="0.02 0.002 0.033" pos="0 0.020 0.033" rgba="1 0 0 0.4"/>
        <geom name="s_wall_s" type="box" size="0.02 0.002 0.033" pos="0 -0.020 0.033" rgba="1 0 0 0.4"/>
        <geom name="s_wall_e" type="box" size="0.002 0.02 0.033" pos="0.020 0 0.033" rgba="1 0 0 0.4"/>
        <geom name="s_wall_w" type="box" size="0.002 0.02 0.033" pos="-0.020 0 0.033" rgba="1 0 0 0.4"/>
    </body>

    <replicate count="2" offset="0.01 0 0">
        <replicate count="2" offset="0 0.01 0">
            <replicate count="8" offset="0 0 0.01">
                <body name="water_particle" pos="0.54 -0.1 0.43">
                    <freejoint/>
                    <geom type="sphere" size="0.004" rgba="0 0.5 1 1" mass="0.0005" margin="0.001" friction="0.01 0.005 0.0001" solref=".002 1" solimp="0.99 0.999 0.0001" damping="0.01" condim="3"/>
                </body>
            </replicate>
        </replicate>
    </replicate>

    <camera name="main_observation" 
    pos="1.2 0.0 1.3" 
    euler="0 0.785 1.5708"/>
  </worldbody>
</mujoco>
